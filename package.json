{
  "name": "digital-factory-chart",
  "private": true,
  "version": "1.0.0",
  "description": "An interactive organizational chart visualization tool that converts Excel spreadsheets into beautiful, hierarchical org charts with collapsible nodes, project grouping, and animated cascade effects.",
  "author": "jason",
  "license": "UNLICENSED",
  "homepage": "https://github.com/JKlaaste/org-hierarchy-react",
  "keywords": [
    "org-chart",
    "organization",
    "hierarchy",
    "react",
    "typescript",
    "excel",
    "visualization",
    "interactive"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.0.5",
    "@xyflow/react": "^12.4.4",
    "he": "^1.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^6.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
